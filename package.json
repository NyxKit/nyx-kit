{
  "name": "nyx-kit",
  "homepage": "http://nyxkit.github.io/nyx-kit",
  "author": "Arne Decant <hello@arnedecant.be>",
  "version": "2.0.11",
  "packageManager": "pnpm@10.18.3",
  "private": false,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint ./src --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint ./src --fix",
    "lint": "run-s lint:*",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:deploy": "gh-pages -d storybook-static",
    "storybook:publish": "storybook build && gh-pages -d storybook-static",
    "prepublishOnly": "pnpm build"
  },
  "types": "./dist/types/index.d.ts",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/types/index.d.ts"
    },
    "./classes": {
      "import": "./dist/classes.mjs",
      "types": "./dist/types/classes.d.ts"
    },
    "./components": {
      "import": "./dist/components.mjs",
      "types": "./dist/types/components.d.ts"
    },
    "./composables": {
      "import": "./dist/composables.mjs",
      "types": "./dist/types/composables.d.ts"
    },
    "./compositions": {
      "import": "./dist/composables.mjs",
      "types": "./dist/types/composables.d.ts"
    },
    "./directives": {
      "import": "./dist/directives.mjs",
      "types": "./dist/types/directives.d.ts"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "types": "./dist/types/types.d.ts"
    },
    "./utils": {
      "import": "./dist/utils.mjs",
      "types": "./dist/types/utils.d.ts"
    },
    "./style.css": {
      "import": "./dist/assets/nyx-kit.css"
    },
    "./eslint": {
      "import": "./eslint/index.mjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "eslint"
  ],
  "repository": {
    "type": "git",
    "URL": "https://github.com/NyxKit/nyx-kit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-task-item": "^3.20.4",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/vue-3": "^3.20.4",
    "lucide-vue-next": "^0.577.0",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.7",
    "tiptap-markdown": "^0.9.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@playwright/test": "^1.55.1",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/cli": "^10.2.19",
    "@storybook/vue3": "^10.2.19",
    "@storybook/vue3-vite": "^10.2.19",
    "@tsconfig/node22": "^22.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/eslint-plugin": "1.1.25",
    "@vue/eslint-config-typescript": "^14.3.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.18.0",
    "eslint-plugin-oxlint": "^0.15.6",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-storybook": "^0.11.3",
    "eslint-plugin-vue": "^9.32.0",
    "gh-pages": "^6.3.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.15.6",
    "sass": "^1.85.0",
    "storybook": "^10.2.19",
    "storybook-dark-mode": "^5.0.0",
    "typescript": "~5.7.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^3.0.5",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "@vue/eslint-config-typescript": "^14.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-oxlint": "^0.15.0",
    "eslint-plugin-vue": "^9.0.0",
    "typescript": "^5.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/eslint-config-typescript": {
      "optional": true
    },
    "eslint": {
      "optional": true
    },
    "eslint-plugin-oxlint": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    }
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "glob": ">=11.1.0",
      "micromatch@4.0.8>picomatch": "2.3.2",
      "@rollup/pluginutils>picomatch": ">=4.0.4",
      "vite>picomatch": ">=4.0.4",
      "tinyglobby>picomatch": ">=4.0.4",
      "fdir>picomatch": ">=4.0.4",
      "@parcel/watcher>picomatch": ">=4.0.4",
      "unplugin>picomatch": ">=4.0.4",
      "unplugin-utils>picomatch": ">=4.0.4",
      "minimatch@3.1.5>brace-expansion": "1.1.13",
      "minimatch@9.0.9>brace-expansion": "2.0.3",
      "minimatch@10.2.3>brace-expansion": "5.0.5",
      "minimatch@10.2.4>brace-expansion": "5.0.5"
    }
  }
}
